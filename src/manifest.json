{
  "manifest_version": 3,
  "name": "BF Filter",
  "version": "1.1.0",
  "description": "Filter low-value posts on YC BF",
  "permissions": ["storage"],
  "host_permissions": [
    "https://bookface.ycombinator.com/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://bookface.ycombinator.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
